#!/usr/bin/env bash
set -eu

selection="$(
  niri msg -j windows \
    | jq -r '
      sort_by(.focus_timestamp.secs, .focus_timestamp.nanos)
      | reverse
      | .[]
      | "\(.id)\t\(.app_id // \"unknown\")\t\((.title // \"(untitled)\") | gsub("[\\r\\n\\t]"; " "))"
    ' \
    | vicinae dmenu --placeholder "Switch window"
)"

[ -n "$selection" ] || exit 0
id="${selection%%$'\t'*}"
[ -n "$id" ] || exit 0

niri msg action focus-window --id "$id" >/dev/null
