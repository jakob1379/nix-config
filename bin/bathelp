#!/usr/bin/env bash

set -uo pipefail
IFS=$'\n\t'

displayUsage() {
	cat <<'EOF'
usage: bhelp <command> [args...]

Show a command's help output through bat.
EOF
}

while getopts ":h" opt; do
	case ${opt} in
		h)
			displayUsage
			exit 0
			;;
		\?)
			echo "Invalid option: $OPTARG" 1>&2
			exit 2
			;;
		:)
			echo "Invalid option: $OPTARG requires an argument" 1>&2
			exit 2
			;;
	esac
done

shift $((OPTIND - 1))

if (($# == 0)); then
	echo "Error: No command provided."
	displayUsage
	exit 2
fi

cmd_name=$1
cmd_args=("$@")

if ! command -v "$cmd_name" >/dev/null 2>&1; then
	echo "Error: Command not found: $cmd_name" 1>&2
	exit 127
fi

help_status=0
if ! help_msg="$("${cmd_args[@]}" --help 2>&1)"; then
	help_msg="$("${cmd_args[@]}" -h 2>&1)" || help_status=$?
fi

bat -pl help <<<"$help_msg"
exit "$help_status"
