#!/usr/bin/env bash
set -euo pipefail

flakePath="${XDG_CONFIG_HOME:-$HOME/.config}/home-manager"

sudo -v
nix-channel --update &
sudo nix-channel --update &
wait

hsu "$@"

uv tool upgrade --all &
rm -rf "$HOME/.cache/opencode"
opencode models --refresh &

wait

sudo -v
nixos-rebuild switch --sudo --flake "${flakePath}" |& nom
