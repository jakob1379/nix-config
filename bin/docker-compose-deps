#!/usr/bin/env bash
#
# docker-compose-deps - Visualize docker-compose service dependencies as a Mermaid graph
#
# Usage: docker-compose-deps [OPTIONS]
#
# Renders a dependency graph of services defined in docker-compose.yml either
# in the terminal using kitty's image display capabilities or in the default
# image viewer via xdg-open.
#
# Dependencies:
#   - docker compose (config export)
#   - jq (JSON parsing)
#   - mermaid-cli (mmdc) (graph rendering)
#   - kitty +kitten icat (terminal image display)
#   - xdg-open (open rendered image in default viewer)
#
# Examples:
#   docker-compose-deps                      # Render graph for docker-compose.yml
#   docker-compose-deps -f docker-compose.yml -f docker-compose.override.yml
#   docker-compose-deps -e .env -e .env.local
#   docker-compose-deps -o                   # Open image in default viewer
#   docker-compose-deps --help               # Show this help message
#
# Author: Generated for home-manager
# Version: 1.0.0
#

set -euo pipefail

readonly SCRIPT_NAME="${0##*/}"
readonly VERSION="1.0.0"

# Arrays to collect docker compose options
declare -a COMPOSE_FILES=()
declare -a ENV_FILES=()
OPEN_OUTPUT=false

# Display usage information
usage() {
    cat <<EOF
Usage: $SCRIPT_NAME [OPTIONS]

Visualize docker-compose service dependencies as a Mermaid graph.

Options:
    -f, --file FILE         Specify compose configuration file (can be used multiple times)
    -e, --env-file FILE     Specify environment file (can be used multiple times)
    -o, --open              Open rendered image in the default viewer
    -h, --help              Show this help message and exit
    -v, --version           Show version information and exit

Description:
    Parses the docker-compose.yml, extracts service dependencies,
    generates a Mermaid flowchart, renders it to PNG, and either displays it
    in the terminal using kitty's image protocol or opens it with xdg-open.

Examples:
    $SCRIPT_NAME                           # Default docker-compose.yml
    $SCRIPT_NAME -f prod.yml               # Use specific file
    $SCRIPT_NAME -f base.yml -f local.yml  # Multiple files
    $SCRIPT_NAME -e .env -e .env.local     # With env files
    $SCRIPT_NAME -o                        # Open in default image viewer

EOF
}

# Display version
version() {
    echo "$SCRIPT_NAME version $VERSION"
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--file)
            if [[ -z "${2:-}" ]]; then
                echo "Error: $1 requires an argument" >&2
                exit 1
            fi
            COMPOSE_FILES+=("$2")
            shift 2
            ;;
        -e|--env-file)
            if [[ -z "${2:-}" ]]; then
                echo "Error: $1 requires an argument" >&2
                exit 1
            fi
            ENV_FILES+=("$2")
            shift 2
            ;;
        -o|--open)
            OPEN_OUTPUT=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            version
            exit 0
            ;;
        -*)
            echo "Error: Unknown option '$1'" >&2
            usage >&2
            exit 1
            ;;
        *)
            echo "Error: Unexpected argument '$1'" >&2
            usage >&2
            exit 1
            ;;
    esac
done

# Build docker compose command options
DOCKER_COMPOSE_OPTS=()
for f in "${COMPOSE_FILES[@]}"; do
    DOCKER_COMPOSE_OPTS+=("-f" "$f")
done
for e in "${ENV_FILES[@]}"; do
    DOCKER_COMPOSE_OPTS+=("--env-file" "$e")
done

# Validate dependencies are available
command -v docker >/dev/null 2>&1 || { echo "Error: docker is required" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "Error: jq is required" >&2; exit 1; }
command -v mmdc >/dev/null 2>&1 || { echo "Error: mermaid-cli (mmdc) is required" >&2; exit 1; }
if [[ "$OPEN_OUTPUT" == true ]]; then
    command -v xdg-open >/dev/null 2>&1 || { echo "Error: xdg-open is required for --open" >&2; exit 1; }
fi

# Check if running in kitty
if [[ "$OPEN_OUTPUT" != true && -z "${KITTY_PID:-}" && -z "${KITTY_WINDOW_ID:-}" ]]; then
    echo "Warning: Not running in kitty terminal. Image display may not work." >&2
fi

# Create temp files
MERMAID_FILE=$(mktemp --suffix=.mmd)
if [[ "$OPEN_OUTPUT" == true ]]; then
    OUTPUT_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/docker-compose-deps"
    mkdir -p "$OUTPUT_DIR"
    OUTPUT_FILE=$(mktemp --tmpdir="$OUTPUT_DIR" docker-compose-deps-XXXXXX.png)
else
    OUTPUT_FILE=$(mktemp --suffix=.png)
fi

cleanup() {
    rm -f "$MERMAID_FILE"

    if [[ "$OPEN_OUTPUT" != true ]]; then
        rm -f "$OUTPUT_FILE"
    fi
}

trap cleanup EXIT

# Get docker compose config and project name
CONFIG_JSON=$(docker compose "${DOCKER_COMPOSE_OPTS[@]}" config --format json)
PROJECT_NAME=$(echo "$CONFIG_JSON" | jq -r '.name // "unknown"')

# Generate mermaid graph from docker-compose config
# Handles both array and object formats for depends_on
echo "$CONFIG_JSON" | jq -r --arg name "$PROJECT_NAME" '
  .services as $services |
  ["---", "title: " + $name + " - Dependency Graph", "---", "graph TD"] +
  ($services |
   to_entries |
   map(
     .key as $service |
     (.value.depends_on // {}) |
     if type == "array" then
       map($service + " --> " + .)
     else
       keys | map($service + " --> " + .)
     end
   ) |
   flatten |
   map("  " + .)) +
  ($services |
   to_entries |
   map(select(.value.depends_on == null or (.value.depends_on | length == 0)) |
       "  " + .key
   )
  ) |
  .[]
' > "$MERMAID_FILE"

# Render with mermaid-cli (white background for visibility on dark terminals)
mmdc --input "$MERMAID_FILE" --output "$OUTPUT_FILE" --backgroundColor white

# Display with kitty or open in default viewer
if [[ "$OPEN_OUTPUT" == true ]]; then
    xdg-open "$OUTPUT_FILE"
    printf 'Opened %s\n' "$OUTPUT_FILE" >&2
else
    kitty +kitten icat "$OUTPUT_FILE"
fi
