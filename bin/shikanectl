#!/usr/bin/env bash

set -euo pipefail

export PATH="@runtimePath@"

readonly REAL_SHIKANECTL="@realShikanectl@"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/shikane"
readonly CONFIG_FILE="$CONFIG_DIR/config.toml"
readonly DEFAULT_PROFILE_NAME="default"
readonly HASHED_PROFILE_REGEX='^[0-9a-f]{64}(-.*)?$'

cleanup() {
  rm -f "${tmp_before:-}" "${tmp_export:-}" "${tmp_export_yaml:-}" "${tmp_config_yaml:-}" "${tmp_result:-}"
}

trap cleanup EXIT

display_root_help() {
  local help_line
  local inserted=false

  while IFS= read -r help_line; do
    printf '%s\n' "$help_line"
    if [[ "$help_line" == "Commands:" ]]; then
      printf '  list    List saved profiles in %s\n' "$CONFIG_FILE"
      printf '  save    Save the current display setup to %s\n' "$CONFIG_FILE"
      printf '  delete  Delete a saved profile from %s\n' "$CONFIG_FILE"
      inserted=true
    fi
  done < <("$REAL_SHIKANECTL" --help)

  if [[ "$inserted" == false ]]; then
    printf '\nCommands:\n'
    printf '  list    List saved profiles in %s\n' "$CONFIG_FILE"
    printf '  save    Save the current display setup to %s\n' "$CONFIG_FILE"
    printf '  delete  Delete a saved profile from %s\n' "$CONFIG_FILE"
  fi
}

display_list_help() {
  cat <<__LIST_HELP__
Usage: shikanectl list [--all]

Lists saved profile names from $CONFIG_FILE.
By default, only profiles matching the current output hash are shown and the
hash prefix is omitted. '*' marks the active setup, '(default)' marks the
saved default alias when it matches a named profile, and legacy hash-only
profiles are shown as 'default (legacy)'.
Use --all to show every saved profile.
__LIST_HELP__
}

display_save_help() {
  cat <<__SAVE_HELP__
Usage: shikanectl save [profile-name] [export args...]

Saves the current display layout into $CONFIG_FILE.
Existing profiles with the same name are replaced.
The shikane daemon is reloaded after the command runs.
Profile names are prefixed with the current output hash unless already hash-prefixed.
If profile-name is omitted or set to $DEFAULT_PROFILE_NAME, a
'<current-output-hash>-$DEFAULT_PROFILE_NAME' profile is replaced and later
selected with 'shikanectl switch $DEFAULT_PROFILE_NAME'.

Any remaining arguments are passed through to 'shikanectl export' unchanged.
__SAVE_HELP__
}

display_delete_help() {
  cat <<__DELETE_HELP__
Usage: shikanectl delete <profile-name>

Deletes the named profile from $CONFIG_FILE.
The shikane daemon is reloaded after the command runs.
Profile names are prefixed with the current output hash unless already hash-prefixed.
__DELETE_HELP__
}

display_switch_help() {
  cat <<__SWITCH_HELP__
Usage: shikanectl switch <profile-name>

Reloads $CONFIG_FILE and switches to the named profile temporarily.
Profile names are prefixed with the current output hash unless already hash-prefixed.
Use $DEFAULT_PROFILE_NAME to switch to the named default profile for the current output hash.
__SWITCH_HELP__
}

current_output_hash() {
  local output_hash

  if ! output_hash=$(
    niri msg --json outputs \
      | yq eval -p=json -o=json -I=0 '[.[] | {"name": .name, "serial": .serial}] | sort_by(.name)' - \
      | sha256sum \
      | cut -d' ' -f1
  ); then
    printf 'Failed to compute the current output hash from niri outputs\n' >&2
    return 1
  fi

  printf '%s\n' "$output_hash"
}

default_profile_name() {
  local output_hash="$1"

  printf '%s-%s\n' "$output_hash" "$DEFAULT_PROFILE_NAME"
}

legacy_default_profile_name() {
  local output_hash="$1"

  printf '%s\n' "$output_hash"
}

normalized_profile_name() {
  local profile_name="${1:-$DEFAULT_PROFILE_NAME}"
  local output_hash="${2:-}"

  if [[ "$profile_name" =~ $HASHED_PROFILE_REGEX ]]; then
    printf '%s\n' "$profile_name"
    return 0
  fi

  if [[ "$profile_name" == "$DEFAULT_PROFILE_NAME" ]]; then
    default_profile_name "$output_hash"
    return 0
  fi

  printf '%s-%s\n' "$output_hash" "$profile_name"
}

is_default_profile_name() {
  local profile_name="$1"
  local output_hash="$2"

  [[ "$profile_name" == "$(default_profile_name "$output_hash")" ]]
}

is_legacy_default_profile_name() {
  local profile_name="$1"
  local output_hash="$2"

  [[ "$profile_name" == "$(legacy_default_profile_name "$output_hash")" ]]
}

profile_exists() {
  local profile_name="$1"

  [[ -f "$CONFIG_FILE" ]] || return 1

  PROFILE_NAME="$profile_name" \
    yq eval -e '((.profile // []) | map(select(.name == strenv(PROFILE_NAME))) | length) > 0' "$CONFIG_FILE" > /dev/null 2>&1
}

profile_body_json() {
  local profile_name="$1"

  PROFILE_NAME="$profile_name" \
    yq eval -p=toml -o=json -I=0 '.profile[] | select(.name == strenv(PROFILE_NAME)) | del(.name)' "$CONFIG_FILE"
}

current_profile_body_json() {
  local tmp_export

  tmp_export=$(mktemp)
  "$REAL_SHIKANECTL" export __CURRENT__ > "$tmp_export"
  yq eval -p=toml -o=json -I=0 '.profile[0] | del(.name)' "$tmp_export"
  rm -f "$tmp_export"
}

stored_default_profile_name() {
  local output_hash="$1"
  local named_default_profile
  local legacy_default_profile

  named_default_profile="$(default_profile_name "$output_hash")"
  if profile_exists "$named_default_profile"; then
    printf '%s\n' "$named_default_profile"
    return 0
  fi

  legacy_default_profile="$(legacy_default_profile_name "$output_hash")"
  if profile_exists "$legacy_default_profile"; then
    printf '%s\n' "$legacy_default_profile"
    return 0
  fi

  return 1
}

named_profile_matching_default() {
  local output_hash="$1"
  local candidate_profiles="$2"
  local stored_default_name
  local default_body_json

  if ! stored_default_name="$(stored_default_profile_name "$output_hash")"; then
    return 1
  fi

  if ! is_default_profile_name "$stored_default_name" "$output_hash"; then
    return 1
  fi

  default_body_json="$(profile_body_json "$stored_default_name")"

  named_profile_matching_body "$output_hash" "$candidate_profiles" "$default_body_json"
}

named_profile_matching_body() {
  local output_hash="$1"
  local candidate_profiles="$2"
  local target_body_json="$3"
  local profile_name
  local profile_body

  while IFS= read -r profile_name; do
    [[ -n "$profile_name" ]] || continue
    is_default_profile_name "$profile_name" "$output_hash" && continue
    is_legacy_default_profile_name "$profile_name" "$output_hash" && continue

    profile_body="$(profile_body_json "$profile_name")"
    if [[ "$profile_body" == "$target_body_json" ]]; then
      printf '%s\n' "$profile_name"
      return 0
    fi
  done <<< "$candidate_profiles"

  return 1
}

display_profile_name() {
  local profile_name="$1"
  local output_hash="$2"

  if [[ "$profile_name" == "$output_hash" ]]; then
    printf '%s\n' "$DEFAULT_PROFILE_NAME"
    return 0
  fi

  if [[ "$profile_name" == "$output_hash-"* ]]; then
    printf '%s\n' "${profile_name#"$output_hash-"}"
    return 0
  fi

  printf '%s\n' "$profile_name"
}

display_profile_alias_name() {
  local profile_name="$1"
  local output_hash="$2"

  if is_legacy_default_profile_name "$profile_name" "$output_hash"; then
    printf '%s (legacy)\n' "$DEFAULT_PROFILE_NAME"
    return 0
  fi

  display_profile_name "$profile_name" "$output_hash"
}

display_profile_label() {
  local profile_name="$1"
  local output_hash="$2"
  local active_profile_name="${3:-}"
  local matching_default_profile_name="${4:-}"
  local display_name

  display_name="$(display_profile_alias_name "$profile_name" "$output_hash")"

  if [[ -n "$matching_default_profile_name" && "$profile_name" == "$matching_default_profile_name" ]]; then
    display_name="$display_name (default)"
  fi

  if [[ -n "$active_profile_name" && "$profile_name" == "$active_profile_name" ]]; then
    printf '* %s\n' "$display_name"
    return 0
  fi

  printf '%s\n' "$display_name"
}

resolve_profile_name() {
  local profile_name="${1:-}"
  local output_hash

  output_hash="$(current_output_hash)"
  normalized_profile_name "$profile_name" "$output_hash"
}

resolve_existing_profile_name() {
  local profile_name="${1:-}"
  local output_hash
  local stored_profile_name

  output_hash="$(current_output_hash)"

  if [[ "$profile_name" == "$DEFAULT_PROFILE_NAME" ]]; then
    if stored_profile_name="$(stored_default_profile_name "$output_hash")"; then
      printf '%s\n' "$stored_profile_name"
      return 0
    fi
  fi

  normalized_profile_name "$profile_name" "$output_hash"
}

convert_toml_to_yaml() {
  local input_file="$1"
  local output_file="$2"

  yq eval -p=toml -o=yaml '.' "$input_file" > "$output_file"
}

snapshot_existing_config() {
  tmp_before=$(mktemp)

  if [[ -f "$CONFIG_FILE" ]]; then
    cp "$CONFIG_FILE" "$tmp_before"
  else
    : > "$tmp_before"
  fi
}

load_existing_config() {
  tmp_config_yaml=$(mktemp)

  if [[ -s "$CONFIG_FILE" ]]; then
    convert_toml_to_yaml "$CONFIG_FILE" "$tmp_config_yaml"
  else
    printf '{}\n' > "$tmp_config_yaml"
  fi
}

apply_result() {
  if cmp -s "$tmp_before" "$tmp_result"; then
    apply_result_changed=false
    return 0
  fi

  mv "$tmp_result" "$CONFIG_FILE"
  apply_result_changed=true
}

reload_config() {
  "$REAL_SHIKANECTL" reload
  maybe_switch_default_profile
}

maybe_switch_default_profile() {
  local output_hash
  local profile_name

  output_hash="$(current_output_hash)"
  if ! profile_name="$(stored_default_profile_name "$output_hash")"; then
    return 0
  fi

  "$REAL_SHIKANECTL" switch "$profile_name"
}

report_apply_result() {
  local profile_name="$1"
  local action_word="$2"
  local output_hash
  local display_name

  output_hash="$(current_output_hash)"
  display_name="$(display_profile_alias_name "$profile_name" "$output_hash")"

  if [[ "$apply_result_changed" == true ]]; then
    printf "%s %s %s\n" "$display_name" "$action_word" "$CONFIG_FILE"
    return 0
  fi

  printf "Profile '%s' is already up to date in %s\n" "$display_name" "$CONFIG_FILE"
}

save_profile() {
  local profile_name="$1"
  local yq_expr
  shift

  mkdir -p "$CONFIG_DIR"

  snapshot_existing_config
  load_existing_config

  tmp_export=$(mktemp)
  tmp_export_yaml=$(mktemp)
  tmp_result=$(mktemp)

  "$REAL_SHIKANECTL" export "$@" "$profile_name" > "$tmp_export"
  convert_toml_to_yaml "$tmp_export" "$tmp_export_yaml"

  PROFILE_NAME="$profile_name" yq eval -e '(.profile | length) == 1 and .profile[0].name == strenv(PROFILE_NAME)' "$tmp_export_yaml" > /dev/null

  yq_expr=$(cat <<'__YQ_EXPR__'
load(strenv(CONFIG_YAML)) as $config |
load(strenv(EXPORT_YAML)) as $export |
$config |
.profile = (($config.profile // []) | map(select(.name != strenv(PROFILE_NAME))) + ($export.profile // []))
__YQ_EXPR__
  )

  CONFIG_YAML="$tmp_config_yaml" \
    EXPORT_YAML="$tmp_export_yaml" \
    PROFILE_NAME="$profile_name" \
    yq eval --null-input -o=toml --expression "$yq_expr" > "$tmp_result"

  apply_result_changed=false
  apply_result "$profile_name" "saved to"
  reload_config
  report_apply_result "$profile_name" "saved to"
}

delete_profile() {
  local profile_name="$1"
  local yq_expr

  if [[ ! -f "$CONFIG_FILE" ]]; then
    printf "Config file not found: %s\n" "$CONFIG_FILE" >&2
    return 1
  fi

  snapshot_existing_config
  load_existing_config
  tmp_result=$(mktemp)

  PROFILE_NAME="$profile_name" yq eval -e '((.profile // []) | map(select(.name == strenv(PROFILE_NAME))) | length) > 0' "$tmp_config_yaml" > /dev/null

  yq_expr=$(cat <<'__YQ_DELETE_EXPR__'
load(strenv(CONFIG_YAML)) as $config |
$config |
.profile = (($config.profile // []) | map(select(.name != strenv(PROFILE_NAME)))) |
del(.profile | select(length == 0))
__YQ_DELETE_EXPR__
  )

  CONFIG_YAML="$tmp_config_yaml" \
    PROFILE_NAME="$profile_name" \
    yq eval --null-input -o=toml --expression "$yq_expr" > "$tmp_result"

  apply_result_changed=false
  apply_result "$profile_name" "deleted from"
  reload_config
  report_apply_result "$profile_name" "deleted from"
}

list_profiles() {
  local show_all="${1:-false}"
  local output_hash
  local matching_profiles
  local active_profile_body_json=""
  local active_profile_name=""
  local matching_default_profile_name=""
  local profile_name

  if [[ ! -s "$CONFIG_FILE" ]]; then
    printf "No saved profiles in %s\n" "$CONFIG_FILE"
    return 0
  fi

  if ! yq eval -e -p=toml '.profile | length > 0' "$CONFIG_FILE" > /dev/null 2>&1; then
    printf "No saved profiles in %s\n" "$CONFIG_FILE"
    return 0
  fi

  if [[ "$show_all" == true ]]; then
    while IFS= read -r profile_name; do
      if [[ "$profile_name" =~ ^[0-9a-f]{64}-$DEFAULT_PROFILE_NAME$ ]]; then
        printf '* %s\n' "$profile_name"
      else
        printf '%s\n' "$profile_name"
      fi
    done < <(yq eval -p=toml -o=yaml -r '.profile[]?.name' "$CONFIG_FILE")
    return 0
  fi

  output_hash="$(current_output_hash)"
  matching_profiles=$(
    OUTPUT_HASH="$output_hash" \
      yq eval -p=toml -o=yaml -r '.profile[]?.name | select(. == strenv(OUTPUT_HASH) or test("^" + strenv(OUTPUT_HASH) + "-"))' "$CONFIG_FILE"
  )

  if [[ -z "$matching_profiles" ]]; then
    printf "No saved profiles for current output hash (%s) in %s\n" "$output_hash" "$CONFIG_FILE"
    return 0
  fi

  local stored_default_name=""
  stored_default_name="$(stored_default_profile_name "$output_hash" || true)"
  active_profile_body_json="$(current_profile_body_json)"
  active_profile_name="$(named_profile_matching_body "$output_hash" "$matching_profiles" "$active_profile_body_json" || true)"
  matching_default_profile_name="$(named_profile_matching_default "$output_hash" "$matching_profiles" || true)"

  while IFS= read -r profile_name; do
    if [[ -n "$matching_default_profile_name" ]] && is_default_profile_name "$profile_name" "$output_hash"; then
      continue
    fi

    if [[ -n "$stored_default_name" && "$stored_default_name" != "$output_hash" && "$profile_name" == "$output_hash" ]]; then
      continue
    fi

    display_profile_label "$profile_name" "$output_hash" "$active_profile_name" "$matching_default_profile_name"
  done <<< "$matching_profiles"
}

main() {
  local subcommand="${1:-}"

  if [[ $# -eq 0 ]]; then
    exec "$REAL_SHIKANECTL"
  fi

  case "$subcommand" in
    -h|--help)
      display_root_help
      return 0
      ;;
    help)
      if [[ $# -eq 1 ]]; then
        display_root_help
        return 0
      fi

      if [[ "$2" == "save" ]]; then
        display_save_help
        return 0
      fi

      if [[ "$2" == "list" ]]; then
        display_list_help
        return 0
      fi

      if [[ "$2" == "delete" ]]; then
        display_delete_help
        return 0
      fi

      if [[ "$2" == "switch" ]]; then
        display_switch_help
        return 0
      fi

      exec "$REAL_SHIKANECTL" "$@"
      ;;
    save)
      shift
      local resolved_profile_name

      if [[ $# -gt 0 && ("$1" == "-h" || "$1" == "--help") ]]; then
        display_save_help
        return 0
      fi

      if [[ $# -eq 0 ]]; then
        resolved_profile_name="$(resolve_profile_name)"
        save_profile "$resolved_profile_name"
        return 0
      fi

      resolved_profile_name="$(resolve_profile_name "$1")"
      save_profile "$resolved_profile_name" "${@:2}"
      ;;
    list)
      shift
      local list_all=false

      if [[ $# -eq 1 ]]; then
        case "$1" in
          -h|--help)
            display_list_help
            return 0
            ;;
          --all)
            list_all=true
            ;;
          *)
            printf "Usage: shikanectl list [--all]\n" >&2
            return 2
            ;;
        esac
      elif [[ $# -gt 1 ]]; then
        printf "Usage: shikanectl list [--all]\n" >&2
        return 2
      fi

      list_profiles "$list_all"
      ;;
    delete)
      shift
      local resolved_profile_name

      if [[ $# -eq 0 ]]; then
        display_delete_help >&2
        return 2
      fi

      if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        display_delete_help
        return 0
      fi

      resolved_profile_name="$(resolve_existing_profile_name "$1")"
      delete_profile "$resolved_profile_name"
      ;;
    switch)
      shift
      local resolved_profile_name

      if [[ $# -eq 0 ]]; then
        display_switch_help >&2
        return 2
      fi

      if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        display_switch_help
        return 0
      fi

      if [[ $# -ne 1 ]]; then
        display_switch_help >&2
        return 2
      fi

      resolved_profile_name="$(resolve_existing_profile_name "$1")"
      "$REAL_SHIKANECTL" reload
      exec "$REAL_SHIKANECTL" switch "$resolved_profile_name"
      ;;
    reload)
      shift

      if [[ $# -eq 0 ]]; then
        reload_config
        return 0
      fi

      exec "$REAL_SHIKANECTL" "$subcommand" "$@"
      ;;
    __current-output-hash)
      current_output_hash
      return 0
      ;;
    __maybe-switch-default)
      maybe_switch_default_profile
      return 0
      ;;
    *)
      exec "$REAL_SHIKANECTL" "$@"
      ;;
  esac
}

main "$@"
