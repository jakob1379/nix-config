#!/usr/bin/env bash

set -euo pipefail

export PATH="@runtimePath@"

readonly REAL_SHIKANECTL="@realShikanectl@"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/shikane"
readonly CONFIG_FILE="$CONFIG_DIR/config.toml"
readonly HASHED_PROFILE_REGEX='^[0-9a-f]{64}(-.*)?$'

cleanup() {
  rm -f "${tmp_before:-}" "${tmp_export:-}" "${tmp_export_yaml:-}" "${tmp_config_yaml:-}" "${tmp_result:-}"
}

trap cleanup EXIT

display_root_help() {
  local help_line
  local inserted=false

  while IFS= read -r help_line; do
    printf '%s\n' "$help_line"
    if [[ "$help_line" == "Commands:" ]]; then
      printf '  list    List saved profiles in %s\n' "$CONFIG_FILE"
      printf '  save    Save the current display setup to %s\n' "$CONFIG_FILE"
      printf '  delete  Delete a saved profile from %s\n' "$CONFIG_FILE"
      inserted=true
    fi
  done < <("$REAL_SHIKANECTL" --help)

  if [[ "$inserted" == false ]]; then
    printf '\nCommands:\n'
    printf '  list    List saved profiles in %s\n' "$CONFIG_FILE"
    printf '  save    Save the current display setup to %s\n' "$CONFIG_FILE"
    printf '  delete  Delete a saved profile from %s\n' "$CONFIG_FILE"
  fi
}

display_list_help() {
  cat <<__LIST_HELP__
Usage: shikanectl list [--all]

Lists saved profile names from $CONFIG_FILE.
By default, only profiles matching the current output hash are shown.
Use --all to show every saved profile.
__LIST_HELP__
}

display_save_help() {
  cat <<__SAVE_HELP__
Usage: shikanectl save [profile-name] [export args...]

Saves the current display layout into $CONFIG_FILE.
Existing profiles with the same name are replaced.
Profile names are prefixed with the current output hash unless already hash-prefixed.
If profile-name is omitted, the current output hash is used as the profile name.

All other commands are passed through to shikanectl unchanged.
__SAVE_HELP__
}

display_delete_help() {
  cat <<__DELETE_HELP__
Usage: shikanectl delete <profile-name>

Deletes the named profile from $CONFIG_FILE.
Profile names are prefixed with the current output hash unless already hash-prefixed.
__DELETE_HELP__
}

current_output_hash() {
  local output_hash

  if ! output_hash=$(
    niri msg --json outputs \
      | yq eval -p=json -o=json -I=0 '[.[] | {"name": .name, "serial": .serial}] | sort_by(.name)' - \
      | sha256sum \
      | cut -d' ' -f1
  ); then
    printf 'Failed to compute the current output hash from niri outputs\n' >&2
    return 1
  fi

  printf '%s\n' "$output_hash"
}

normalized_profile_name() {
  local profile_name="${1:-}"
  local output_hash="${2:-}"

  if [[ -z "$profile_name" ]]; then
    printf '%s\n' "$output_hash"
    return 0
  fi

  if [[ "$profile_name" =~ $HASHED_PROFILE_REGEX ]]; then
    printf '%s\n' "$profile_name"
    return 0
  fi

  printf '%s-%s\n' "$output_hash" "$profile_name"
}

resolve_profile_name() {
  local profile_name="${1:-}"
  local output_hash

  output_hash="$(current_output_hash)"
  normalized_profile_name "$profile_name" "$output_hash"
}

convert_toml_to_yaml() {
  local input_file="$1"
  local output_file="$2"

  yq eval -p=toml -o=yaml '.' "$input_file" > "$output_file"
}

snapshot_existing_config() {
  tmp_before=$(mktemp)

  if [[ -f "$CONFIG_FILE" ]]; then
    cp "$CONFIG_FILE" "$tmp_before"
  else
    : > "$tmp_before"
  fi
}

load_existing_config() {
  tmp_config_yaml=$(mktemp)

  if [[ -s "$CONFIG_FILE" ]]; then
    convert_toml_to_yaml "$CONFIG_FILE" "$tmp_config_yaml"
  else
    printf '{}\n' > "$tmp_config_yaml"
  fi
}

apply_result() {
  local profile_name="$1"
  local action_word="$2"

  if cmp -s "$tmp_before" "$tmp_result"; then
    printf "Profile '%s' is already up to date in %s\n" "$profile_name" "$CONFIG_FILE"
    return 0
  fi

  mv "$tmp_result" "$CONFIG_FILE"
  printf "%s %s %s\n" "$profile_name" "$action_word" "$CONFIG_FILE"
}

save_profile() {
  local profile_name="$1"
  local yq_expr
  shift

  mkdir -p "$CONFIG_DIR"

  snapshot_existing_config
  load_existing_config

  tmp_export=$(mktemp)
  tmp_export_yaml=$(mktemp)
  tmp_result=$(mktemp)

  "$REAL_SHIKANECTL" export "$@" "$profile_name" > "$tmp_export"
  convert_toml_to_yaml "$tmp_export" "$tmp_export_yaml"

  PROFILE_NAME="$profile_name" yq eval -e '(.profile | length) == 1 and .profile[0].name == strenv(PROFILE_NAME)' "$tmp_export_yaml" > /dev/null

  yq_expr=$(cat <<'__YQ_EXPR__'
load(strenv(CONFIG_YAML)) as $config |
load(strenv(EXPORT_YAML)) as $export |
$config |
.profile = (($config.profile // []) | map(select(.name != strenv(PROFILE_NAME))) + ($export.profile // []))
__YQ_EXPR__
  )

  CONFIG_YAML="$tmp_config_yaml" \
    EXPORT_YAML="$tmp_export_yaml" \
    PROFILE_NAME="$profile_name" \
    yq eval --null-input -o=toml --expression "$yq_expr" > "$tmp_result"

  apply_result "$profile_name" "saved to"
}

delete_profile() {
  local profile_name="$1"
  local yq_expr

  if [[ ! -f "$CONFIG_FILE" ]]; then
    printf "Config file not found: %s\n" "$CONFIG_FILE" >&2
    return 1
  fi

  snapshot_existing_config
  load_existing_config
  tmp_result=$(mktemp)

  PROFILE_NAME="$profile_name" yq eval -e '((.profile // []) | map(select(.name == strenv(PROFILE_NAME))) | length) > 0' "$tmp_config_yaml" > /dev/null

  yq_expr=$(cat <<'__YQ_DELETE_EXPR__'
load(strenv(CONFIG_YAML)) as $config |
$config |
.profile = (($config.profile // []) | map(select(.name != strenv(PROFILE_NAME)))) |
del(.profile | select(length == 0))
__YQ_DELETE_EXPR__
  )

  CONFIG_YAML="$tmp_config_yaml" \
    PROFILE_NAME="$profile_name" \
    yq eval --null-input -o=toml --expression "$yq_expr" > "$tmp_result"

  apply_result "$profile_name" "deleted from"
}

list_profiles() {
  local show_all="${1:-false}"
  local output_hash
  local matching_profiles

  if [[ ! -s "$CONFIG_FILE" ]]; then
    printf "No saved profiles in %s\n" "$CONFIG_FILE"
    return 0
  fi

  if ! yq eval -e -p=toml '.profile | length > 0' "$CONFIG_FILE" > /dev/null 2>&1; then
    printf "No saved profiles in %s\n" "$CONFIG_FILE"
    return 0
  fi

  if [[ "$show_all" == true ]]; then
    yq eval -p=toml -o=yaml -r '.profile[]?.name' "$CONFIG_FILE"
    return 0
  fi

  output_hash="$(current_output_hash)"
  matching_profiles=$(
    OUTPUT_HASH="$output_hash" \
      yq eval -p=toml -o=yaml -r '.profile[]?.name | select(. == strenv(OUTPUT_HASH) or test("^" + strenv(OUTPUT_HASH) + "-"))' "$CONFIG_FILE"
  )

  if [[ -z "$matching_profiles" ]]; then
    printf "No saved profiles for current output hash (%s) in %s\n" "$output_hash" "$CONFIG_FILE"
    return 0
  fi

  printf '%s\n' "$matching_profiles"
}

main() {
  local subcommand="${1:-}"

  if [[ $# -eq 0 ]]; then
    exec "$REAL_SHIKANECTL"
  fi

  case "$subcommand" in
    -h|--help)
      display_root_help
      return 0
      ;;
    help)
      if [[ $# -eq 1 ]]; then
        display_root_help
        return 0
      fi

      if [[ "$2" == "save" ]]; then
        display_save_help
        return 0
      fi

      if [[ "$2" == "list" ]]; then
        display_list_help
        return 0
      fi

      if [[ "$2" == "delete" ]]; then
        display_delete_help
        return 0
      fi

      exec "$REAL_SHIKANECTL" "$@"
      ;;
    save)
      shift
      local resolved_profile_name

      if [[ $# -gt 0 && ("$1" == "-h" || "$1" == "--help") ]]; then
        display_save_help
        return 0
      fi

      if [[ $# -eq 0 ]]; then
        resolved_profile_name="$(resolve_profile_name)"
        save_profile "$resolved_profile_name"
        return 0
      fi

      resolved_profile_name="$(resolve_profile_name "$1")"
      save_profile "$resolved_profile_name" "${@:2}"
      ;;
    list)
      shift
      local list_all=false

      if [[ $# -eq 1 ]]; then
        case "$1" in
          -h|--help)
            display_list_help
            return 0
            ;;
          --all)
            list_all=true
            ;;
          *)
            printf "Usage: shikanectl list [--all]\n" >&2
            return 2
            ;;
        esac
      elif [[ $# -gt 1 ]]; then
        printf "Usage: shikanectl list [--all]\n" >&2
        return 2
      fi

      list_profiles "$list_all"
      ;;
    delete)
      shift
      local resolved_profile_name

      if [[ $# -eq 0 ]]; then
        display_delete_help >&2
        return 2
      fi

      if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        display_delete_help
        return 0
      fi

      resolved_profile_name="$(resolve_profile_name "$1")"
      delete_profile "$resolved_profile_name"
      ;;
    *)
      exec "$REAL_SHIKANECTL" "$@"
      ;;
  esac
}

main "$@"
