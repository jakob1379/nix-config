#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

readonly SCRIPT_NAME="${0##*/}"

usage() {
   cat << EOF
Usage: ${SCRIPT_NAME} [DIR] [OPTIONS]

Analyze noqa comments in Python files and display statistics.

ARGUMENTS:
   DIR             Directory to search (default: current directory)

OPTIONS:
   -h, --help      Show this help message and exit
   -d, --dir DIR   Search in DIR instead of current directory
   -p, --pattern   Pattern to search (default: "# noqa")

EXAMPLES:
   ${SCRIPT_NAME}
   ${SCRIPT_NAME} ./backend
   ${SCRIPT_NAME} --dir ./backend
   ${SCRIPT_NAME} ./backend --pattern "type: ignore"

EOF
}

print_rule_totals() {
   local raw_data="$1"

   gum style --foreground 212 --bold --underline "NOQA Rule Totals"
   echo "${raw_data}" | awk '{
       if (match($0, /# noqa[: \t]+([^#]+)/)) {
           content = substr($0, RSTART + 7, RLENGTH - 7)
           sub(/^[ \t]*/, "", content)
           n = split(content, parts, /[ \t]*,[ \t]*|[ \t]+/)
           for (i=1; i<=n; i++) {
               rule = parts[i]
               gsub(/^[\047"]+|[\047"]+$/, "", rule)
               if (rule != "" && rule !~ /^#/) count[rule]++
           }
       }
   } END {
       for (rule in count) printf "%s\t%d\n", rule, count[rule]
   }' | sort -t$'\t' -k2 -nr | gum table --print --separator $'\t' \
       --columns "Rule,Count" --widths 20,10
}

print_file_counts() {
    local search_dir="$1"
    local pattern="$2"
    local max_file_width="${3:-48}"
    local term_width
    term_width="$(tput cols 2>/dev/null || echo 100)"

    # Adjust widths based on terminal size
    local rules_width=45
    if [[ $term_width -lt 100 ]]; then
        max_file_width=30
        rules_width=30
    fi

    gum style --foreground 212 --bold --underline "NOQA Counts Per File"

    ag "${pattern}" "${search_dir}" 2>/dev/null | \
    awk -F':' '
    {
        file=$1
        # Extract content after noqa:
        if (match($0, /# noqa[: \t]+([^#]+)/)) {
            content = substr($0, RSTART + 7, RLENGTH - 7)
            gsub(/^[ \t]+|[ \t]+$/, "", content)
            # Split on comma or space
            n = split(content, parts, /[ \t]*,[ \t]*|[ \t]+/)
            for (i=1; i<=n; i++) {
                rule = parts[i]
                gsub(/^[\047"]+|[\047"]+$/, "", rule)
                if (rule != "" && rule !~ /^#/) {
                    key = file "\t" rule
                    counts[key]++
                    totals[file]++
                }
            }
        }
    }
    END {
        for (key in counts) {
            split(key, p, "\t")
            printf "%s\t%s\t%d\t%d\n", p[1], p[2], counts[key], totals[p[1]]
        }
    }' | \
    sort -t$'\t' -k1,1 -k3,3nr | \
    awk -v max_rule_len="$((rules_width - 3))" -v max_file_len="$max_file_width" -F'\t' '
    BEGIN { OFS="\t" }
    {
        if ($1 != prev && prev != "") print_row()
        prev = $1
        prev_total = $4
        rules[++n] = $2
        rule_counts[n] = $3
    }
    END { print_row() }

    function print_row() {
        formatted = ""
        visible = 0
        for (i=1; i<=n; i++) {
            entry = rules[i] ": " rule_counts[i]
            test = formatted (formatted ? ", " : "") entry
            if (length(test) > max_rule_len && i > 1) {
                formatted = formatted ", +" (n-visible) " more"
                break
            }
            formatted = test
            visible++
        }

        f = prev
        if (length(f) > max_file_len) {
            f = "..." substr(f, length(f) - max_file_len + 4)
        }

        print f, formatted, prev_total
        delete rules; delete rule_counts; n = 0
    }' | \
    sort -t$'\t' -k3 -nr | \
    gum table --print --separator $'\t' \
        --columns "File,Rules,Total" \
        --widths "$max_file_width,$rules_width,8"
}

main() {
   local search_dir="."
   local pattern="# noqa"

   while [[ $# -gt 0 ]]; do
       case $1 in
           -h|--help)
               usage
               exit 0
               ;;
           -d|--dir)
               search_dir="${2:-.}"
               shift 2
               ;;
            -p|--pattern)
                pattern="${2:-# noqa}"
               shift 2
               ;;
           -*)
               echo "Unknown option: $1" >&2
               usage >&2
               exit 1
               ;;
           *)
               # Positional argument - use as directory
               search_dir="$1"
               shift
               ;;
       esac
   done

   if [[ ! -d "${search_dir}" ]]; then
       echo "Error: Directory not found: ${search_dir}" >&2
       exit 1
   fi

   local raw_data
   raw_data=$(gum spin --spinner dot --title "Scanning for '${pattern}' in ${search_dir}..." -- ag "${pattern}" "${search_dir}" 2>/dev/null || true)

   if [[ -z "${raw_data}" ]]; then
       gum style --foreground 82 --bold "✓ No '${pattern}' comments found in ${search_dir}"
       exit 0
   fi

   print_rule_totals "${raw_data}"
   echo ""
   print_file_counts "${search_dir}" "${pattern}"
}

main "$@"
